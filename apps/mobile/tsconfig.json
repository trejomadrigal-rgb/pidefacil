{
  "extends": "@pidefacil/tsconfig/react-native.json",
  "compilerOptions": {
    "paths": {
      "@pidefacil/types": [
        "../../packages/types/src"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "pidefacil-mobile",
    "node_modules"
  ]
}
